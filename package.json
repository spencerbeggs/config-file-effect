{
	"name": "config-file-effect",
	"version": "0.3.0",
	"private": true,
	"description": "Composable config file loading for Effect with pluggable codecs, resolution strategies, and merge behaviors.",
	"keywords": [
		"effect",
		"config",
		"configuration",
		"toml",
		"json",
		"config-file",
		"layer",
		"dependency-injection",
		"typescript"
	],
	"homepage": "https://github.com/spencerbeggs/config-file-effect#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/config-file-effect/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/config-file-effect.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run --passWithNoTests",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"smol-toml": "^1.7.0"
	},
	"devDependencies": {
		"@effect/cluster": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/rpc": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"@savvy-web/bundler": "^1.1.14",
		"@savvy-web/silk": "^2.4.4",
		"@types/node": "catalog:silk",
		"@vitest-agent/plugin": "^1.1.9",
		"effect": "catalog:silk"
	},
	"peerDependencies": {
		"@effect/platform": "catalog:silkPeers",
		"@effect/platform-node": "catalog:silkPeers",
		"effect": "catalog:silkPeers"
	},
	"peerDependenciesMeta": {
		"@effect/platform-node": {
			"optional": true
		}
	},
	"packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
	"engines": {
		"node": ">=24.11.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.5.0",
				"onFail": "ignore"
			}
		]
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true,
			"github": "@spencerbeggs/config-file-effect"
		}
	}
}
