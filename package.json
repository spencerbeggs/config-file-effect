{
	"name": "config-file-effect",
	"version": "0.2.0",
	"private": true,
	"description": "Composable config file loading for Effect with pluggable codecs, resolution strategies, and merge behaviors.",
	"keywords": [
		"effect",
		"config",
		"configuration",
		"toml",
		"json",
		"config-file",
		"layer",
		"dependency-injection",
		"typescript"
	],
	"homepage": "https://github.com/spencerbeggs/config-file-effect#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/config-file-effect/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/config-file-effect.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"build:dev": "rslib build --config-loader native --env-mode dev",
		"build:inspect": "rslib inspect --config-loader native --env-mode npm --verbose",
		"build:prod": "rslib build --config-loader native --env-mode npm",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run",
		"ci:version": "savvy-changesets version && biome format --write .",
		"commit:check": "savvy-commit check",
		"commit:init": "savvy-commit init",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 '**/*.{md,mdx}' --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"smol-toml": "^1.6.1"
	},
	"devDependencies": {
		"@effect/platform": "catalog:silkPeers",
		"@effect/platform-node": "catalog:silkPeers",
		"@savvy-web/changesets": "^0.10.0",
		"@savvy-web/commitlint": "^0.9.1",
		"@savvy-web/lint-staged": "^1.1.0",
		"@savvy-web/rslib-builder": "^0.20.7",
		"@savvy-web/vitest": "^1.3.2",
		"effect": "catalog:silkPeers"
	},
	"peerDependencies": {
		"@effect/platform": "catalog:silkPeers",
		"@effect/platform-node": "catalog:silkPeers",
		"effect": "catalog:silkPeers"
	},
	"peerDependenciesMeta": {
		"@effect/platform-node": {
			"optional": true
		}
	},
	"packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.33.4",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "24.11.0",
				"onFail": "ignore"
			}
		]
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/github",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
